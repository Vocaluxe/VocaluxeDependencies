<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Target Name="ffmpegBeforeBuild" BeforeTargets="BeforeBuild">
    <Message Text="x86 target detected" Importance="normal" Condition=" '$(Platform)'=='x86'"/>
    <Message Text="x64 target detected" Importance="normal" Condition=" '$(Platform)'=='x64'"/>
    <Message Text="Any CPU target detected" Importance="normal" Condition=" '$(Platform)'=='Any CPU'"/>


    <ItemGroup>
      <FilesToCopy Include="$(MSBuildThisFileDirectory)..\x86\**\*.*" Condition=" '$(Platform)'=='x86' AND '$(Configuration)' != 'ReleaseLinux' AND '$(Configuration)' != 'DebugLinux' "/>
    </ItemGroup>

    <ItemGroup>
      <FilesToCopy Include="$(MSBuildThisFileDirectory)..\x64\**\*.*" Condition=" '$(Platform)'=='x64' AND '$(Configuration)' != 'ReleaseLinux' AND '$(Configuration)' != 'DebugLinux' "/>
    </ItemGroup>

    <ItemGroup>
      <FilesToCopy Include="$(MSBuildThisFileDirectory)..\Any CPU\**\*.*" Condition=" '$(Platform)'=='Any CPU' AND '$(Configuration)' != 'ReleaseLinux' AND '$(Configuration)' != 'DebugLinux' "/>
    </ItemGroup>

    <ItemGroup>
      <FilesToCopyAll Include="$(MSBuildThisFileDirectory)..\All\**\*.*" Condition=" '$(Configuration)' != 'ReleaseLinux' AND '$(Configuration)' != 'DebugLinux' "/>
    </ItemGroup>

    <Copy
        SourceFiles="@(FilesToCopy)"
        DestinationFiles="@(FilesToCopy->'$(TargetDir)libs\unmanaged\%(RecursiveDir)%(Filename)%(Extension)')"
        />

    <Copy
        SourceFiles="@(FilesToCopyAll)"
        DestinationFiles="@(FilesToCopyAll->'$(TargetDir)libs\unmanaged\%(RecursiveDir)%(Filename)%(Extension)')"
        />
  </Target>
</Project>